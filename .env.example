# Copy to .env for local use. Do not commit real values.

# Token from Telegram BotFather. Prefer configuring it with:
#   /telegram:configure <token>
# inside Claude Code, which writes ~/.claude/channels/telegram/.env.
# CLI-only alternative:
#   TELEGRAM_BOT_TOKEN=<token> scripts/configure-telegram.sh
TELEGRAM_BOT_TOKEN=

# Optional. Only needed for boot/restart notifications from boot.sh.
# The Telegram channel itself uses /telegram:access pairing instead.
TELEGRAM_CHAT_ID=

# Claude Code subscription/OAuth auth is used by default.
# For unattended launchd use, run once:
#   claude setup-token

CLAUDE_RESTART_DELAY=5
CLAUDE_BYPASS_PERMISSIONS=1
CLAUDE_SESSION_NAME=nullevi03

# Optional: resume a fixed session UUID instead of the latest session in this directory.
# CLAUDE_SESSION_ID=

# Optional:
# CLAUDE_MODEL=sonnet
# CLAUDE_EFFORT=medium
